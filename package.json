{
  "name": "myshows",
  "version": "1.1.3",
  "description": "Automatically marks currently watched episode in MyShows",
  "main": "src/index.js",
  "scripts": {
    "build": "rm -rf dist && parcel build .",
    "test": "vitest run",
    "commit": "cz"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@parcel/transformer-sass": "^2.16.4",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.4",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "commitizen": "^4.2.4",
    "cz-conventional-changelog": "^3.3.0",
    "iina-plugin-definition": "^0.99.3",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "parcel": "^2.16.4",
    "parcel-optimizer-webview": "git+https://github.com/iina/parcel-optimizer-webview.git"
  },
  "browserslist": "safari >= 9",
  "entry": "src/index.js",
  "targets": {
    "main": false,
    "global": {
      "distDir": "./dist/",
      "source": "src/global.ts",
      "isLibrary": false
    },
    "entry": {
      "distDir": "./dist/",
      "source": "src/index.ts",
      "isLibrary": false
    }
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
