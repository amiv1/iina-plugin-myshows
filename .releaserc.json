{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node scripts/bump-info-version.js ${nextRelease.version} && npm run build && /Applications/IINA.app/Contents/MacOS/iina-plugin pack ."
      }
    ],
    [
      "@semantic-release/npm",
      {
        "npmPublish": false
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["package.json", "Info.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "*.iinaplgz",
            "label": "IINA Plugin v${nextRelease.version}"
          }
        ]
      }
    ]
  ]
}
